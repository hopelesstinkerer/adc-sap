{
  "name": "adc-sap",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "nx run-many --target=build",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "nx run-many --target=typecheck",
    "format": "prettier --write .",
    "prepare": "lefthook install"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ],
    "ignore": [
      "pnpm-lock.yaml",
      "**/.agents/**",
      "**/dist/**",
      "**/coverage/**"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint/js": "10.0.1",
    "eslint": "10.7.0",
    "lefthook": "2.1.10",
    "lint-staged": "17.0.8",
    "nx": "23.1.0",
    "prettier": "3.9.5",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
